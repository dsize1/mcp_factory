{
  "name": "mcp-factory",
  "version": "1.0.0",
  "description": "A monorepo for developing MCP servers using FastMCP framework",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "dev:mcp": "pnpm --filter mcp-dev-tools dev",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0"
  },
  "author": "",
  "license": "MIT"
}