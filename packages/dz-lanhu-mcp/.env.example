# 蓝湖 MCP 服务器配置示例
# 复制此文件为 .env 并填入你的配置值
# ⚠️ 注意：不要将 .env 文件提交到 git！

# ==============================================
# 必需配置
# ==============================================

# 蓝湖 Cookie（必需）
# 获取方法：登录蓝湖网页版，打开浏览器开发者工具，从请求头中复制 Cookie
# 在浏览器中按 F12 打开开发者工具 -> Network 标签 -> 刷新页面 -> 点击任意蓝湖请求 -> 复制请求头中的 Cookie
LANHU_COOKIE=""

# ==============================================
# 可选配置
# ==============================================

# 数据存储目录
# 默认值：./data
# 用于缓存 Axure 资源、设计稿截图、留言数据等
DATA_DIR="./data"

# HTTP 请求超时时间（秒）
# 默认值：30
HTTP_TIMEOUT="30"

# 浏览器视口尺寸（影响截图渲染）
# 默认值：1920x1080
VIEWPORT_WIDTH="1920"
VIEWPORT_HEIGHT="1080"

# ==============================================
# 飞书机器人配置（可选）
# ==============================================

# 飞书 Webhook URL
# 获取方法：在飞书管理后台创建机器人后获取
# 留空则禁用飞书通知功能
FEISHU_WEBHOOK_URL=""

# ==============================================
# 调试选项
# ==============================================

# 调试模式
# 设为 true 启用详细日志输出
DEBUG="false"

# ==============================================
# 使用说明
# ==============================================
#
# 1. Cookie 安全：
#    - 妥善保管你的 LANHU_COOKIE
#    - 不要将 .env 文件提交到 git
#    - 定期更换 Cookie
#
# 2. 飞书集成：
#    - 可选但推荐用于团队协作
#    - 在飞书管理后台创建自定义机器人
#    - 将机器人添加到目标群聊
#    - 复制 Webhook URL 到此处
#
# 3. 性能调优：
#    - 根据网络状况调整 HTTP_TIMEOUT
#    - 修改 DATA_DIR 到 SSD 路径可提升缓存性能